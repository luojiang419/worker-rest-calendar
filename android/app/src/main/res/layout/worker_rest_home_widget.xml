<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/widget_small"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/small_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●  今日状态"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/small_status"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/small_countdown_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="距离休息还有"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/small_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/small_week_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxLines="1"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_medium"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/medium_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="本周节奏"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/medium_week_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:maxLines="1"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/medium_week_row"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal" />

        <TextView
            android:id="@+id/medium_next_rest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_large"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/large_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="26dp"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView style="@style/WidgetWeekday" android:text="一" />
            <TextView style="@style/WidgetWeekday" android:text="二" />
            <TextView style="@style/WidgetWeekday" android:text="三" />
            <TextView style="@style/WidgetWeekday" android:text="四" />
            <TextView style="@style/WidgetWeekday" android:text="五" />
            <TextView style="@style/WidgetWeekday" android:text="六" />
            <TextView style="@style/WidgetWeekday" android:text="日" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/large_calendar_grid"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/large_legend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● 工作   ● 休息   ● 调休   ● 请假"
            android:textSize="10sp" />
    </LinearLayout>
</FrameLayout>
